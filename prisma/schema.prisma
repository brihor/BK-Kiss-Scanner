generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Signal {
  id          String    @id @default(cuid())
  pair        String    @unique
  assetType   AssetType
  direction   String
  entry       Float
  takeProfit  Float
  stopLoss    Float
  signalTime  DateTime
  lockedUntil DateTime
  createdAt   DateTime  @default(now())
  high        Float
  low         Float
  lowerBand   Float
  rsi         Float
  stochasticK Float
  updatedAt   DateTime  @updatedAt
  upperBand   Float
}

enum AssetType {
  FOREX
  INDICES
  GOLD
  CRYPTO
}
