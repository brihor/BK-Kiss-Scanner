generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AssetType {
  FOREX
  INDICES
  GOLD
  CRYPTO
}

model Signal {
  id            String    @id @default(cuid())

  pair          String    @unique
  assetType     AssetType

  direction     String

  entry         Float
  takeProfit    Float
  stopLoss      Float

  signalTime    DateTime
  lockedUntil   DateTime

  rsi           Float
  stochasticK   Float
  upperBand     Float
  lowerBand     Float
  high          Float
  low           Float

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}